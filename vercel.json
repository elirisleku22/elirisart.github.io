{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.jpg",
      "use": "@vercel/static"
    },
    {
      "src": "*.png",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/admin", "dest": "/api/admin.js" },
    { "src": "/api/client", "dest": "/api/client.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
